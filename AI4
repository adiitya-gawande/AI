2) import nltk 
from nltk.tokenize import word_tokenize 
from nltk.corpus import stopwords 
from collections import Counter

3) nltk.download('punkt') 
nltk.download('punkt_tab') 
nltk.download('stopwords') 
nltk.download('averaged_perceptron_tagger_eng')
nltk.download('averaged_perceptron_tagger') 

4) text = """
Artificial Intelligence and Machine Learning are important technologies
in modern computer science.
"""

5) tokens = word_tokenize(text) 
print("\nTokens:\n", tokens) 

6) freq = Counter(tokens) 
print("\nWord Frequency:\n", freq) 

7) stop_words = set(stopwords.words('english')) 
filtered_words = [word for word in tokens if word.lower() not in stop_words] 
print("\nAfter Removing Stopwords:\n", filtered_words) 

8) pos_tags = nltk.pos_tag(filtered_words) 
print("\nPOS Tagging:\n", pos_tags) 
