1) import random

2) def heuristic(state):

    attacks = 0

    n = len(state)

    for i in range(n):

        for j in range(i + 1, n):

            if state[i] == state[j] or abs(state[i] - state[j]) == j - i:

                attacks += 1

    return attacks

3) def random_state(n):

    return [random.randint(0, n - 1) for _ in range(n)]

4) def hill_climbing(n):

    current = random_state(n)

    current_h = heuristic(current)

    while True:

        neighbors = []

        for col in range(n):

            for row in range(n):

                if row != current[col]:

                    neighbor = current.copy()

                    neighbor[col] = row

                    neighbors.append(neighbor)

        next_state = current

        next_h = current_h

        for neighbor in neighbors:

            h = heuristic(neighbor)

            if h < next_h:

                next_state = neighbor

                next_h = h

        if next_h >= current_h:

            break

        current, current_h = next_state, next_h

    return current, current_h

